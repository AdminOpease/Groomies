# --- Supabase (required) -----------------------------------------------------
# Get these from your Supabase project: Settings → API
# The browser talks to Supabase directly using the anon key. This is BY DESIGN —
# Row Level Security policies in the database decide what each visitor can read.
# The anon key is meant to be public; never paste the service_role key here.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# --- Public site canonical URL (required in production) ----------------------
# Used for sitemap.xml, robots.txt, JSON-LD, canonical tags.
# Local dev falls back to http://localhost:3000; set this on Cloudflare.
NEXT_PUBLIC_SITE_URL=https://www.groomies.uk

# --- Security tests only (do NOT ship to Cloudflare) -------------------------
# Needed by tests/ to set up and tear down test data. This key bypasses RLS —
# keep it out of the browser bundle, Cloudflare env vars, and version control.
# Supabase Studio → Project Settings → API Keys → service_role key
SUPABASE_SERVICE_ROLE_KEY=

# --- Transactional email (Resend) --------------------------------------------
# Booking confirmations + owner "new booking" alerts.
# When unset, emails are skipped (with a warning in server logs) — the booking
# itself still succeeds. Get a key at https://resend.com/api-keys.
# For real launch, verify your sending domain in Resend to send from your own address.
RESEND_API_KEY=

# The From address. MUST be on a domain verified in Resend or sends fail with a
# 403. Unset falls back to Resend's sandbox sender, which only delivers to the
# account owner's own address — fine locally, never in production.
RESEND_FROM=Groomies <hello@groomies.uk>

# --- Stripe (dormant until deposits are switched on) -------------------------
# Set these when you enable business_settings.payments_enabled. Until then,
# bookings confirm immediately in the DB and never hit Stripe.
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# --- Cloudflare Turnstile (bot protection on the booking form) ---------------
# When unset, the form falls back to just the honeypot field and none of the
# Turnstile code runs. Set BOTH or neither.
#
# Get them at: Cloudflare dashboard → Turnstile → Add widget
#   - Widget mode: Managed
#   - Hostnames:   groomies.uk, www.groomies.uk  (add localhost for local dev)
#
# ⚠️ NEXT_PUBLIC_TURNSTILE_SITE_KEY is a BUILD variable in Cloudflare, not a
# runtime secret — it is inlined at build time, so it needs a redeploy before
# the widget appears. TURNSTILE_SECRET_KEY is a runtime secret and applies
# immediately. Setting only the secret logs a loud error and lets bookings
# through unverified, rather than blocking every customer.
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=
# TURNSTILE_SECRET_KEY=

# Cloudflare Web Analytics (optional, free, cookieless — no consent banner needed).
# Get from: Cloudflare dashboard → Analytics & Logs → Web Analytics → Add a site.
# Leave unset to disable; the script is only rendered when this is present.
NEXT_PUBLIC_CF_BEACON_TOKEN=
