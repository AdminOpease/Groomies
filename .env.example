# --- Supabase (required) -----------------------------------------------------
# Get these from your Supabase project: Settings → API
# The browser talks to Supabase directly using the anon key. This is BY DESIGN —
# Row Level Security policies in the database decide what each visitor can read.
# The anon key is meant to be public; never paste the service_role key here.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# --- Security tests only (do NOT ship to Cloudflare) -------------------------
# Needed by tests/ to set up and tear down test data. This key bypasses RLS —
# keep it out of the browser bundle, Cloudflare env vars, and version control.
# Supabase Studio → Project Settings → API Keys → service_role key
SUPABASE_SERVICE_ROLE_KEY=

# --- Later phases (leave blank for now) --------------------------------------
# Resend (transactional email — used by Cloudflare functions)
# RESEND_API_KEY=

# Stripe (payments — added when payments_enabled is switched on)
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Cloudflare Turnstile (CAPTCHA for the booking form)
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=
# TURNSTILE_SECRET_KEY=
