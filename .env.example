# --- Supabase (required) -----------------------------------------------------
# Get these from your Supabase project: Settings → API
# The browser talks to Supabase directly using the anon key. This is BY DESIGN —
# Row Level Security policies in the database decide what each visitor can read.
# The anon key is meant to be public; never paste the service_role key here.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# --- Public site canonical URL (required in production) ----------------------
# Used for sitemap.xml, robots.txt, JSON-LD, canonical tags.
# Local dev falls back to http://localhost:3000; set this on Cloudflare.
NEXT_PUBLIC_SITE_URL=https://groomies.example.workers.dev

# --- Security tests only (do NOT ship to Cloudflare) -------------------------
# Needed by tests/ to set up and tear down test data. This key bypasses RLS —
# keep it out of the browser bundle, Cloudflare env vars, and version control.
# Supabase Studio → Project Settings → API Keys → service_role key
SUPABASE_SERVICE_ROLE_KEY=

# --- Transactional email (Resend) --------------------------------------------
# Booking confirmations + owner "new booking" alerts.
# When unset, emails are skipped (with a warning in server logs) — the booking
# itself still succeeds. Get a key at https://resend.com/api-keys.
# For real launch, verify your sending domain in Resend to send from your own address.
RESEND_API_KEY=

# --- Stripe (dormant until deposits are switched on) -------------------------
# Set these when you enable business_settings.payments_enabled. Until then,
# bookings confirm immediately in the DB and never hit Stripe.
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# --- Cloudflare Turnstile (bot protection on the booking form) ---------------
# When unset, the form falls back to just the honeypot field. Enable in
# production. Site key ships to the browser; secret stays server-only.
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=
# TURNSTILE_SECRET_KEY=
